@echo off
title Flow - Audio Visualizer
cd /d "%~dp0"

where python >nul 2>nul
if errorlevel 1 (
    echo Python is not installed.
    echo Get it from https://www.python.org/downloads/ - check "Add to PATH" during install.
    pause
    exit /b 1
)

python -c "import pygame, numpy, pyaudiowpatch" >nul 2>nul
if errorlevel 1 (
    echo First run: installing required packages...
    python -m pip install --quiet pygame numpy pyaudiowpatch
)

start "" pythonw visualizer.py
exit /b 0
